---
interface Source {
  title: string;
  url: string;
}

interface Props {
  sources: Source[];
}

const { sources } = Astro.props;
const sourcesLabel = sources?.length
  ? `${sources.length} ${sources.length === 1 ? "source" : "sources"}`
  : "";

function getDomain(url: string): string {
  try {
    return new URL(url).hostname.replace("www.", "");
  } catch {
    return url;
  }
}
---

{
  sources?.length ? (
    <div class="not-prose" data-sources>
      <button
        type="button"
        class="text-neutral-400 dark:text-neutral-500 hover:text-neutral-600 dark:hover:text-neutral-300 transition-colors cursor-pointer bg-transparent border-none p-0 text-sm flex items-center gap-1.5"
        data-sources-toggle
        aria-expanded="false"
      >
        <svg
          class="w-3 h-3 transition-transform duration-200"
          fill="currentColor"
          viewBox="0 0 20 20"
          data-sources-arrow
        >
          <path
            fill-rule="evenodd"
            d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z"
            clip-rule="evenodd"
          />
        </svg>
        <span>{sourcesLabel}</span>
      </button>

      <div
        class="grid transition-all duration-200 ease-out grid-rows-[0fr] opacity-0"
        data-sources-panel
      >
        <ul class="overflow-hidden list-none pl-[1.125rem] m-0 pt-1 pb-1">
          {
            sources.map((source) => (
              <li class="m-0 !pb-0">
                <a
                  href={source.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="plain-link group flex flex-wrap items-center gap-x-1.5 gap-y-0 text-sm py-0.5 text-neutral-500 dark:text-neutral-400 hover:text-neutral-700 dark:hover:text-neutral-200 transition-colors"
                >
                  <span>{source.title}</span>
                  <span class="flex items-center gap-1.5">
                    <span class="text-neutral-300 dark:text-neutral-600">·</span>
                    <span class="text-sm text-neutral-400 dark:text-neutral-500">
                      {getDomain(source.url)}
                    </span>
                    <svg
                      class="w-2.5 h-2.5 opacity-0 group-hover:opacity-50 transition-opacity"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                      />
                    </svg>
                  </span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  ) : null
}

<script>
  document.querySelectorAll<HTMLElement>("[data-sources]").forEach((root) => {
    const toggle = root.querySelector<HTMLButtonElement>("[data-sources-toggle]");
    const arrow = root.querySelector<SVGElement>("[data-sources-arrow]");
    const panel = root.querySelector<HTMLElement>("[data-sources-panel]");

    if (!toggle || !arrow || !panel) {
      return;
    }

    toggle.addEventListener("click", () => {
      const isOpen = toggle.getAttribute("aria-expanded") === "true";
      const nextOpen = !isOpen;

      toggle.setAttribute("aria-expanded", String(nextOpen));
      arrow.classList.toggle("rotate-90", nextOpen);
      panel.classList.toggle("grid-rows-[1fr]", nextOpen);
      panel.classList.toggle("opacity-100", nextOpen);
      panel.classList.toggle("grid-rows-[0fr]", !nextOpen);
      panel.classList.toggle("opacity-0", !nextOpen);
    });
  });
</script>
