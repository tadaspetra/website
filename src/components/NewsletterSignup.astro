---
interface Props {
  variant?: "home" | "compact";
}

const { variant = "compact" } = Astro.props;
const isHome = variant === "home";
---

<section
  class:list={[
    "letter-box",
    isHome ? "letter-box-home" : "letter-box-compact",
  ]}
  data-letter-box
>
  <div class="letter-box-copy">
    <h2>Newsletter</h2>
    <p>
      Sign up for founder insights, AI observations, and clear explanations of
      things I'm learning along the way.
    </p>
  </div>

  <form class="letter-box-form" data-letter-form>
    <label class="sr-only" for={`letter-email-${variant}`}>Email address</label>
    <input
      id={`letter-email-${variant}`}
      name="email"
      type="email"
      autocomplete="email"
      placeholder="Enter your email"
      required
      data-letter-email
    />
    <button type="submit" data-letter-submit>
      Subscribe
    </button>
  </form>

  <p class="letter-box-message" data-letter-message aria-live="polite">
  </p>
</section>

<script>
  const subscribedStorageKey = "newsletter-signed-up";

  document.querySelectorAll<HTMLElement>("[data-letter-box]").forEach((box) => {
    const form = box.querySelector<HTMLFormElement>("[data-letter-form]");
    const emailInput = box.querySelector<HTMLInputElement>("[data-letter-email]");
    const submitButton = box.querySelector<HTMLButtonElement>("[data-letter-submit]");
    const message = box.querySelector<HTMLElement>("[data-letter-message]");

    if (!form || !emailInput || !submitButton || !message) {
      return;
    }

    if (localStorage.getItem(subscribedStorageKey) === "true") {
      box.hidden = true;
      return;
    }

    document.documentElement.classList.add("show-letter-box");

    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      const email = emailInput.value.trim();
      if (!email) {
        return;
      }

      submitButton.disabled = true;
      message.textContent = "Signing you up...";

      try {
        const response = await fetch("/api/newsletter", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({ email }),
        });

        const result = await response.json();

        if (!response.ok) {
          throw new Error(result?.message || "Something went wrong.");
        }

        localStorage.setItem(subscribedStorageKey, "true");
        form.reset();
        message.textContent = "You're on the list. Thank you.";
        window.setTimeout(() => {
          box.hidden = true;
        }, 1200);
      } catch (error) {
        message.textContent =
          error instanceof Error
            ? error.message
            : "Something went wrong. Please try again.";
      } finally {
        submitButton.disabled = false;
      }
    });
  });
</script>
