---
interface Item {
  href: string;
  title: string;
  description: string;
  logo: string;
  logoClass?: string;
  logoText?: string;
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;

const heightToSize: Record<string, string> = {
  "h-3": "0.875rem",
  "h-4": "1rem",
  "h-5": "1.125rem",
  "h-6": "1.25rem",
};

function getHeightClass(className: string): string {
  return className.split(" ").find((c) => c.match(/^h-\d+$/)) || "h-6";
}
---

{
  items?.length ? (
    <div class="mt-0 pt-0" data-previous-work>
      <button
        type="button"
        class="flex items-center gap-3 w-full cursor-pointer bg-transparent border-none p-0 group"
        data-previous-work-toggle
        aria-expanded="false"
      >
        <span
          class="text-xs tracking-widest uppercase transition-colors whitespace-nowrap my-1 text-neutral-400 dark:text-neutral-500 group-hover:text-neutral-500 dark:group-hover:text-neutral-400 mx-4"
          data-previous-work-label
        >
          Show previous work <span class="leading-none relative -top-px">+</span>
        </span>
        <span
          class="hidden flex-1 h-px bg-neutral-200 dark:bg-neutral-700"
          data-previous-work-rule
        />
      </button>

      <div
        class="grid transition-all duration-200 ease-out grid-rows-[0fr] opacity-0"
        data-previous-work-panel
      >
        <div class="overflow-hidden pt-2 grid grid-cols-1 sm:grid-cols-2">
          {
            items.map((item) => {
              const heightClass = getHeightClass(item.logoClass || "h-6");
              const fontSize = heightToSize[heightClass] || "1.5rem";

              return (
                <a
                  href={item.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="plain-link block px-4 py-3 rounded-lg hover:bg-neutral-100 dark:hover:bg-neutral-800 transition-colors group"
                >
                  <div>
                    <div class="flex items-center gap-2 mb-1">
                      <img
                        src={item.logo}
                        alt={item.title}
                        class={`${item.logoClass || "h-6"} w-auto max-w-56 object-contain dark:invert`}
                      />
                      {item.logoText && (
                        <span
                          class="-ml-0.5 leading-none font-medium tracking-tighter"
                          style={`font-size: ${fontSize};`}
                        >
                          {item.logoText}
                        </span>
                      )}
                    </div>
                    <div class="text-sm sm:text-base text-neutral-500 dark:text-neutral-400 mt-0.5">
                      {item.description}
                    </div>
                  </div>
                </a>
              );
            })
          }
        </div>
      </div>
    </div>
  ) : null
}

<script>
  document.querySelectorAll<HTMLElement>("[data-previous-work]").forEach((root) => {
    const toggle = root.querySelector<HTMLButtonElement>("[data-previous-work-toggle]");
    const label = root.querySelector<HTMLElement>("[data-previous-work-label]");
    const panel = root.querySelector<HTMLElement>("[data-previous-work-panel]");
    const rule = root.querySelector<HTMLElement>("[data-previous-work-rule]");

    if (!toggle || !label || !panel || !rule) {
      return;
    }

    toggle.addEventListener("click", () => {
      const isOpen = toggle.getAttribute("aria-expanded") === "true";
      const nextOpen = !isOpen;

      toggle.setAttribute("aria-expanded", String(nextOpen));
      label.innerHTML = nextOpen
        ? "Close previous work"
        : 'Show previous work <span class="leading-none relative -top-px">+</span>';
      label.classList.toggle("text-neutral-500", nextOpen);
      label.classList.toggle("dark:text-neutral-400", nextOpen);
      label.classList.toggle("text-neutral-400", !nextOpen);
      label.classList.toggle("dark:text-neutral-500", !nextOpen);
      label.classList.toggle("group-hover:text-neutral-500", !nextOpen);
      label.classList.toggle("dark:group-hover:text-neutral-400", !nextOpen);
      label.classList.toggle("mx-4", !nextOpen);
      rule.classList.toggle("hidden", !nextOpen);
      panel.classList.toggle("grid-rows-[1fr]", nextOpen);
      panel.classList.toggle("opacity-100", nextOpen);
      panel.classList.toggle("grid-rows-[0fr]", !nextOpen);
      panel.classList.toggle("opacity-0", !nextOpen);
    });
  });
</script>
